[alias]
	stat = diff --stat

[delta]
  features = plain-style
  side-by-side = false
  line-numbers = true
  line-numbers-left-format = "{nm:^4}"
  line-numbers-right-format = "{np:^4} "
  line-numbers-left-style = "#7f5558" "#2b1618"
  line-numbers-right-style = "#5f8a67" "#102018"
  minus-style = syntax "#2b1618"
  plus-style = syntax "#102018"
  decorations = false
  file-style = plain
  hunk-header-decoration-style = none
  hunk-header-file-style = white
  hunk-header-line-number-style = white
  hunk-label = "@@"
  # hunk-header-style = "line-number syntax"
  hunk-header-style = omit
  file-style = "yellow"
  file-mapping-style = yellow
  file-decoration-style = none
  file-modified-label = "Modified file"
  file-added-label = "Added file"
  file-removed-label = "Removed file"
  file-copied-label = "Copied file"
  file-renamed-label = "Rnamed file"
  syntax-theme = mmgeorge-treesitter
  max-line-distance = 0.8
  # paging = auto
  paging = never

