{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/permissions-schema.json",
  "permission": {
    "bash": {
      "python": "allow",
      "python *": "allow",
      "pnpm *": "allow",
      "printf": "allow",
      "printf *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "find": "allow",
      "find *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "sed": "allow",
      "sed *": "allow",
      "awk": "allow",
      "awk *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "uniq": "allow",
      "uniq *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "tsgo": "allow",
      "tsgo *": "allow",
      "git commit": "deny",
      "git commit *": "deny",
      "gh": "deny",
      "gh *": "deny",
      "az": "deny",
      "az *": "deny",
      "azcopy": "deny",
      "azcopy *": "deny",
      "bash": "deny",
      "bash *": "deny",
      "bash.exe": "deny",
      "bash.exe *": "deny",
      "sh": "deny",
      "sh *": "deny",
      "sh.exe": "deny",
      "sh.exe *": "deny",
      "powershell": "deny",
      "powershell *": "deny",
      "powershell.exe": "deny",
      "powershell.exe *": "deny",
      "pwsh": "deny",
      "pwsh *": "deny",
      "pwsh.exe": "deny",
      "pwsh.exe *": "deny",
      "cmd": "deny",
      "cmd *": "deny",
      "cmd.exe": "deny",
      "cmd.exe *": "deny"
    },
    "write": {
      "**": "allow"
    },
    "webfetch": {
      "*": "allow"
    }
  }
}
