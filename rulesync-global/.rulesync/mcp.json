{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/mcp-schema.json",
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp",
      "default_tools_approval_mode": "approve"
    },
    "docs-mcp": {
      "command": "docs-mcp",
      "default_tools_approval_mode": "approve"
    },
    "sem": {
      "command": "sem",
      "args": [
        "mcp"
      ],
      "default_tools_approval_mode": "approve"
    },
    "google-dev-knowledge": {
      "type": "http",
      "url": "https://developerknowledge.googleapis.com/mcp",
      "default_tools_approval_mode": "approve",
      "env_http_headers": {
        "X-Goog-Api-Key": "GOOGLE_DEV_KNOWLEDGE_MCP_KEY"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9222"
      ],
      "default_tools_approval_mode": "approve"
    },
    "github": {
      "command": "github-mcp-server",
      "args": [
        "stdio",
        "--toolsets=context,actions,discussions,issues,labels,notifications,orgs,projects,pull_requests,repos,users"
      ],
      "envVars": [
        "GITHUB_PERSONAL_ACCESS_TOKEN"
      ],
      "default_tools_approval_mode": "approve"
    },
    "openaiDeveloperDocs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp",
      "default_tools_approval_mode": "approve"
    },
    "terminal": {
      "command": "terminal-mcp",
      "args": [
        "--headless"
      ],
      "default_tools_approval_mode": "approve"
    }
  }
}
