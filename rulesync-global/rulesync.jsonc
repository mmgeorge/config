{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": [
    "claudecode",
    "codexcli",
    "antigravity-cli",
    "copilotcli"
  ],
  "features": [
    "rules",
    "ignore",
    "mcp",
    "commands",
    "subagents",
    "skills",
    "hooks"
  ],
  "outputRoots": [
    "."
  ],
  "global": true,
  "delete": false,
  "verbose": false,
  "silent": false,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false
}
