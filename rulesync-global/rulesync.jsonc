{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": {
    "claudecode": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "hooks", "permissions"],
    "codexcli": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "hooks"],
    "antigravity-cli": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "hooks", "permissions"],
    "copilotcli": ["rules", "ignore", "mcp", "commands", "subagents", "skills", "hooks", "permissions"]
  },
  "outputRoots": [
    "."
  ],
  "global": true,
  "delete": false,
  "verbose": false,
  "silent": false,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false
}
